// ── Réponse admin aux signalements ──
async function submitReply(id){
  if(!isAdmin) return;
  const txt=document.getElementById('reply-txt-'+id).value.trim();
  if(!txt) return showToast('⚠️ Rédigez une réponse','var(--rouge)');
  const btn=document.querySelector(`#reply-form-${id} .btn-reply-send`);
  if(btn){btn.textContent='⏳';btn.disabled=true;}
  const {error}=await sb.from('signalements').update({
    reponse_admin:txt,
    reponse_date:new Date().toISOString()
  }).eq('id',id);
  if(btn){btn.textContent='✅ Publier la réponse';btn.disabled=false;}
  if(error) return showToast('❌ '+error.message,'var(--rouge)');
  showToast('✅ Réponse publiée !','var(--prairie)');
  loadAlertes();
}

function editReply(id){
  const form=document.getElementById('reply-form-'+id);
  const txt=document.getElementById('reply-txt-'+id);
  if(form&&txt){
    txt.value=replyCache[id]||'';
    form.style.display='block';
    txt.focus();
  }
}

function cancelReply(id){
  const form=document.getElementById('reply-form-'+id);
  if(form) form.style.display='none';
}

