const MUR_TTL = 48 * 3600 * 1000; // 48h en ms

async function loadMur(){
  const cutoff = new Date(Date.now() - MUR_TTL).toISOString();
  const {data} = await sb.from('mur_voisins')
    .select('*').order('created_at',{ascending:false}).limit(80);
  murData = (data||[]).filter(m => (Date.now()-new Date(m.created_at).getTime()) < MUR_TTL);
  // Nettoyage silencieux des anciens messages
  sb.from('mur_voisins').delete().lt('created_at', cutoff).then(()=>{});
  renderMur();
}

function renderMur(){
  const list = document.getElementById('mur-list');
  const tot  = document.getElementById('mur-total');
  let items = murData;
  if(murFilter==='recent'){
    const t2h = Date.now()-2*3600*1000;
    items = murData.filter(m=>new Date(m.created_at).getTime()>t2h);
  } else if(murFilter==='mine' && CP){
    items = murData.filter(m=>m.auteur_id===CP.id);
  }
  tot.textContent = items.length+' message'+(items.length>1?'s':'');
  if(!items.length){
    list.innerHTML=`<div class="mur-empty">
      <div class="mur-empty-ico">💬</div>
      <div class="mur-empty-h">Pas encore de message…</div>
      <div class="mur-empty-s">Soyez le premier à briser la glace !</div>
    </div>`;
    return;
  }
  list.innerHTML = items.map(m=>{
    const age = Date.now()-new Date(m.created_at).getTime();
    const left = MUR_TTL-age;
    const h = Math.floor(left/3600000), mn = Math.floor((left%3600000)/60000);
    const ttlTxt = h>1 ? h+'h restantes' : mn>0 ? mn+'min restantes' : 'Expire bientôt';
    const likes = (m.liked_by||[]);
    const liked = CP && likes.includes(CP.id);
    const canDel = CP && (m.auteur_id===CP.id || isAdmin);
    return `<div class="mur-card" id="mc-${m.id}">
      <div class="mur-card-head">
        ${makeAvHTML(m.auteur_nom||'?', m.auteur_color||0, 'sm')}
        <div class="mur-card-info">
          <div class="mur-card-name">${esc(m.auteur_nom||'Voisin')}${m.auteur_id===CP?.id?' <span style="font-family:monospace;font-size:8px;color:var(--roseau);">(vous)</span>':''}</div>
          <div class="mur-card-when">${fmtDate(m.created_at)}</div>
        </div>
        <div class="mur-ttl-pill">⏳ ${ttlTxt}</div>
      </div>
      <div class="mur-card-body">${esc(m.contenu).replace(/\n/g,'<br>')}</div>
      <div class="mur-card-foot">
        <button class="mur-like${liked?' liked':''}" onclick="likeMur(${m.id})">
          ${liked?'❤️':'🤍'} <span id="ml-${m.id}">${likes.length||0}</span>
        </button>
        ${canDel?`<button class="mur-del" onclick="deleteMur(${m.id})" title="Supprimer">🗑️</button>`:''}
      </div>
    </div>`;
  }).join('');
}

