function getInitials(nom) {
  if (!nom) return '?';
  const parts = nom.trim().split(' ').filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[parts.length-1][0]).toUpperCase();
  return parts[0].substring(0,2).toUpperCase();
}

function makeAvHTML(nom, colorId, size='', extra='') {
  const col = AV_COLORS[colorId] || AV_COLORS[0];
  const sizeClass = size === 'lg' ? 'lg' : size === 'xl' ? 'xl' : size === 'sm' ? 'sm' : '';
  return `<div class="av-circle ${sizeClass} ${col.cls}" style="${extra}">${getInitials(nom)}</div>`;
}

