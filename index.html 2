async function voterChoixMultiple(projetId, optionId, optionLabel){
  if(!CP) return;
  const key='projet_'+projetId;
  if(userVotes[key]) return showToast('Vous avez déjà voté sur ce projet','var(--roseau)');
  const {error}=await sb.from('votes').insert({user_id:CP.id,objet_type:'projet',objet_id:projetId,valeur:String(optionId)});
  if(error){
    if(error.code==='23505'||error.message?.includes('conflict')||error.message?.includes('unique')){
      await loadUserVotes();
      renderProjets();
      return showToast('✅ Vote déjà enregistré','var(--roseau)');
    }
    return showToast('❌ Erreur vote : '+error.message,'var(--rouge)');
  }
  // Incrémenter les votes de l'option
  const {data:opt}=await sb.from('options_vote').select('votes').eq('id',optionId).single();
  await sb.from('options_vote').update({votes:(opt?.votes||0)+1}).eq('id',optionId);
  userVotes[key]=String(optionId);
  CP.votes=(CP.votes||0)+1;
  await sb.from('profiles').update({votes:CP.votes}).eq('id',CP.id);
  await addXP(8,'Vote choix multiple');
  showToast(`🗳️ Vote enregistré pour "${optionLabel}" !`,'var(--prairie)');
  checkBadges();
  // Rafraîchir le cache
  const {data:opts}=await sb.from('options_vote').select('*').eq('projet_id',projetId);
  if(opts) optionsCache[projetId]=opts;
  renderProjets();
}

async function voterProjet(id,valeur){
  if(!CP) return;
  const key='projet_'+id;
  if(userVotes[key]) return showToast('✅ Vous avez déjà voté sur ce projet','var(--roseau)');
  const {error}=await sb.from('votes').insert({user_id:CP.id,objet_type:'projet',objet_id:id,valeur});
  if(error){
    // 409 = vote déjà en base mais pas en cache → resync
    if(error.code==='23505'||error.message?.includes('conflict')||error.message?.includes('unique')){
      await loadUserVotes();
      renderProjets();
      return showToast('✅ Vote déjà enregistré','var(--roseau)');
    }
    return showToast('❌ Erreur vote : '+error.message,'var(--rouge)');
  }
  const col=valeur==='pour'?'votes_pour':'votes_contre';
  const {data:proj}=await sb.from('projets').select(col).eq('id',id).single();
  await sb.from('projets').update({[col]:(proj[col]||0)+1}).eq('id',id);
  userVotes[key]=valeur;
  CP.votes=(CP.votes||0)+1;
  await sb.from('profiles').update({votes:CP.votes}).eq('id',CP.id);
  await addXP(8,'Vote projet');
  showToast(valeur==='pour'?'👍 Vote Pour !':'👎 Vote Contre !',valeur==='pour'?'var(--prairie)':'var(--roseau)');
  checkBadges();loadProjets();
}

// ── Supprimer son propre contenu ──
async function ownDelete(table, id, listName){
  if(!CP) return;
  if(!confirm('Supprimer définitivement votre publication ?')) return;
  const {error}=await sb.from(table).delete().eq('id',id).eq('auteur_id',CP.id);
  if(error) return showToast('❌ Impossible de supprimer','var(--rouge)');
  showToast('🗑️ Supprimé','var(--roseau)');
  if(listName==='als'){CP.alertes=Math.max(0,(CP.alertes||0)-1);await sb.from('profiles').update({alertes:CP.alertes}).eq('id',CP.id);loadAlertes();}
  else if(listName==='ann'){CP.contrib=Math.max(0,(CP.contrib||0)-1);await sb.from('profiles').update({contrib:CP.contrib}).eq('id',CP.id);loadAnnonces();}
  updateUI();
}

