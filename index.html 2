async function loadThermo(){
  // Charger toutes les questions, la plus récente = active
  const {data} = await sb.from('thermo_questions')
    .select('*').order('created_at',{ascending:false}).limit(20);
  thermoData = data || [];
  renderThermo();
  renderThermoHomeWidget();
}

function getActiveQuestion(){
  if(!thermoData.length) return null;
  // La plus récente et non clôturée (ou date_fin non dépassée)
  return thermoData.find(q => {
    if(q.cloturee) return false;
    if(q.date_fin && new Date(q.date_fin) < new Date()) return false;
    return true;
  }) || null;
}

function hasVotedThermo(questionId){
  if(!CP) return false;
  const q = thermoData.find(x=>x.id===questionId);
  if(!q) return false;
  return (q.votants||[]).includes(CP.id);
}

function getThermoVotedOption(questionId){
  if(!CP) return null;
  const q = thermoData.find(x=>x.id===questionId);
  if(!q) return null;
  // Chercher dans quel option l'utilisateur a voté
  const opts = q.options || [];
  for(let i=0;i<opts.length;i++){
    if((opts[i].votants||[]).includes(CP.id)) return i;
  }
  return null;
}

function getThermoTotal(question){
  return (question.options||[]).reduce((s,o)=>(s+(o.votes||0)),0);
}

// ─── Rendu page thermo ───
function renderThermo(){
  const active = getActiveQuestion();
  const activeEl  = document.getElementById('thermo-active-section');
  const historyEl = document.getElementById('thermo-history-section');

  // Section active
  if(active){
    const hasVoted = hasVotedThermo(active.id);
    const votedIdx = getThermoVotedOption(active.id);
    const total    = getThermoTotal(active);
    activeEl.innerHTML = `
      <div style="margin-bottom:24px;">
        <div class="st-row"><div>
          <div class="st-tag">Question de la semaine</div>
          <div class="st-h">${esc(active.question)}</div>
        </div></div>
        ${hasVoted?'<div class="thermo-voted-badge">✅ Vous avez voté · '+total+' participant'+(total>1?'s':'')+'</div>':''}
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:16px;">
          ${(active.options||[]).map((opt,i)=>{
            const pct   = total>0?Math.round((opt.votes||0)/total*100):0;
            const isWin = hasVoted && (opt.votes||0)===Math.max(...(active.options||[]).map(o=>o.votes||0)) && (opt.votes||0)>0;
            const myVote= votedIdx===i;
            return `<button class="thermo-opt${hasVoted?(isWin?' winner':' voted'):''}" onclick="${!hasVoted?'voteThermo('+active.id+','+i+')':''}" ${hasVoted?'style="cursor:default;"':''}>
              ${hasVoted?`<div class="thermo-opt-bar" style="width:${pct}%;"></div>`:''}
              <div class="thermo-opt-content">
                <span class="thermo-opt-emoji">${opt.emoji||'▸'}</span>
                <span class="thermo-opt-label">${esc(opt.label)}${myVote?' <span style="font-size:10px;color:var(--aube);">← votre choix</span>':''}</span>
                ${hasVoted?`<span class="thermo-opt-pct">${pct}%${isWin?' 🏆':''}</span>`:''}
              </div>
            </button>`;
          }).join('')}
        </div>
        <div class="thermo-meta">
          <span>📊 ${total} vote${total>1?'s':''}</span>
          ${active.date_fin?`<span>⏰ Jusqu'au ${new Date(active.date_fin).toLocaleDateString('fr-FR',{day:'numeric',month:'long'})}</span>`:''}
          ${isAdmin?`<button onclick="cloturerThermo(${active.id})" style="background:none;border:none;font-size:10px;color:var(--rouge);cursor:pointer;padding:0;font-family:'DM Mono',monospace;">Clôturer ✕</button>`:''}
        </div>
      </div>`;
  } else {
    activeEl.innerHTML = `<div style="background:rgba(44,63,95,.06);border:1px dashed rgba(44,63,95,.2);border-radius:12px;padding:24px;text-align:center;margin-bottom:24px;">
