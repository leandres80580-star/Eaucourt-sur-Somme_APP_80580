// Cache pour les options de vote
let optionsCache = {}; // projet_id -> [{id, label, votes}]

async function loadProjets(){
  const {data}=await sb.from('projets').select('*').order('created_at',{ascending:false});
  projData=data||[];
  // Charger les options — réinitialiser le cache pour éviter les doublons
  optionsCache = {};
  const cmIds=(projData.filter(p=>p.type_vote==='choix_multiple')).map(p=>p.id);
  if(cmIds.length){
    const {data:opts}=await sb.from('options_vote').select('*').in('projet_id',cmIds);
    if(opts) opts.forEach(o=>{
      if(!optionsCache[o.projet_id]) optionsCache[o.projet_id]=[];
      optionsCache[o.projet_id].push(o);
    });
  }
  renderProjets();
}

