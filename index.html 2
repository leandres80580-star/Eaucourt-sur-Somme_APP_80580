//  ACTU
// ══════════════════════════════════════════════
let actuData = [];

async function loadActu() {
  const { data } = await sb.from('actus').select('*').order('created_at', { ascending: false });
  actuData = data || [];
  renderActuHome();
}

function renderActuHome() {
  const section = document.getElementById('actu-home-section');
  if (!section) return;

  // Barre admin
  const adminBar = isAdmin ? `
    <div class="actu-admin-bar visible">
      <div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--admin);letter-spacing:1px;">📰 Gestion des articles</div>
      <button class="btn ba bsm" onclick="openModal('modal-actu')">+ Nouvel article</button>
    </div>` : '';

  if (!actuData.length) {
    section.innerHTML = adminBar + `<div class="actu-empty-msg">📰 Aucun article publié pour l'instant — la mairie partagera ici les actualités du village.</div>`;
    return;
  }

  const articles = actuData.map(a => {
    const d = new Date(a.created_at);
    const dateStr = d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
    return `<div class="actu-article">
      ${a.image_url ? `<img class="actu-article-img" src="${esc(a.image_url)}" alt="${esc(a.titre)}" loading="lazy">` : ''}
      <div class="actu-article-body">
        <div class="actu-article-badge">📰 Actualité · ${dateStr}</div>
        <div class="actu-article-titre">${esc(a.titre)}</div>
        <div class="actu-article-texte">${esc(a.texte)}</div>
        <div class="actu-article-foot">
          <div class="actu-article-source">Mairie d'Eaucourt-sur-Somme</div>
          ${isAdmin ? `<button class="actu-del-btn" onclick="deleteActu(${a.id})" title="Supprimer">🗑️</button>` : ''}
        </div>
      </div>
    </div>`;
  }).join('');

  section.innerHTML = adminBar + articles;
}

function previewActuPhoto(input) {
  const file = input.files[0];
  if (!file) return;
  const preview = document.getElementById('actu-photo-preview');
  const label = document.getElementById('actu-upload-label');
  const reader = new FileReader();
  reader.onload = e => {
    preview.src = e.target.result;
    preview.style.display = 'block';
    if (label) label.style.display = 'none';
  };
  reader.readAsDataURL(file);
}

async function submitActu() {
  if (!isAdmin) return;
  const titre = document.getElementById('actu-titre').value.trim();
  const texte = document.getElementById('actu-texte').value.trim();
  if (!titre || !texte) return showToast('⚠️ Titre et texte obligatoires', 'var(--rouge)');

  const btn = document.getElementById('btn-actu-sub');
  btn.innerHTML = '<span class="sp"></span>'; btn.classList.add('loading-btn');

  // Upload photo si présente
  let image_url = null;
  const photoInput = document.getElementById('actu-photo-input');
  if (photoInput && photoInput.files[0]) {
    btn.innerHTML = '<span class="sp"></span> Upload…';
    const compressed = await compressImage(photoInput.files[0]);
    const path = `actus/${Date.now()}_${Math.random().toString(36).slice(2)}.jpg`;
    const { data: up, error: upErr } = await sb.storage.from('agenda-images').upload(path, compressed, { contentType: 'image/jpeg', upsert: false });
    if (upErr) { btn.innerHTML = 'Publier'; btn.classList.remove('loading-btn'); return showToast('❌ Erreur photo : ' + upErr.message, 'var(--rouge)'); }
    const { data: urlData } = sb.storage.from('agenda-images').getPublicUrl(path);
    image_url = urlData.publicUrl;
  }

  const { error } = await sb.from('actus').insert({ titre, texte, image_url, auteur_id: CP.id, auteur_nom: CP.nom });
  btn.innerHTML = 'Publier l\'article'; btn.classList.remove('loading-btn');
  if (error) return showToast('❌ ' + error.message, 'var(--rouge)');

  // Reset form
  document.getElementById('actu-titre').value = '';
  document.getElementById('actu-texte').value = '';
  if (photoInput) photoInput.value = '';
  const preview = document.getElementById('actu-photo-preview');
  if (preview) { preview.src = ''; preview.style.display = 'none'; }
  const label = document.getElementById('actu-upload-label');
  if (label) label.style.display = 'block';

  closeModal('modal-actu');
  showToast('📰 Article publié !', 'var(--eau)');
  await loadActu();
}

async function deleteActu(id) {
  if (!isAdmin || !confirm('Supprimer cet article ?')) return;
  const { error } = await sb.from('actus').delete().eq('id', id);
  if (error) return showToast('❌ Erreur', 'var(--rouge)');
  actuData = actuData.filter(a => a.id !== id);
  renderActuHome();
  showToast('🗑️ Article supprimé', 'var(--roseau)');
}

