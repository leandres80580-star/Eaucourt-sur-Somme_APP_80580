async function addXP(amount, label){
  if(!CP) return;
  const newXp=(CP.xp||0)+amount;
  const oldLv=getLevel(CP.xp||0).n;
  CP.xp=newXp;
  await sb.from('profiles').update({xp:newXp}).eq('id',CP.id);
  showXpToast('+'+amount+' XP — '+label);
  if(getLevel(newXp).n!==oldLv){showToast('🚀 Niveau supérieur : '+getLevel(newXp).n+' !','var(--aube)','var(--boue)');launchConfetti();}
  checkBadges();updateUI();
}

async function checkBadges(){
  if(!CP) return;
  const earned=CP.badges||[], toUnlock=[];
  for(const b of BADGES){
    if(earned.includes(b.id)) continue;
    let ok=false;
    if(b.id==='b1'&&(CP.alertes||0)>=1)ok=true;
    if(b.id==='b2'&&(CP.alertes||0)>=3)ok=true;
    if(b.id==='b3'&&(CP.votes||0)>=1)ok=true;
    if(b.id==='b4'&&(CP.votes||0)>=5)ok=true;
    if(b.id==='b5'&&(CP.contrib||0)>=1)ok=true;
    if(b.id==='b6'&&(CP.xp||0)>=100)ok=true;
    if(b.id==='b7'&&(CP.xp||0)>=250)ok=true;
    if(b.id==='b8'&&(CP.alertes||0)>=1&&(CP.votes||0)>=1&&(CP.contrib||0)>=1)ok=true;
    if(ok)toUnlock.push(b.id);
  }
  if(toUnlock.length){
    const nb=[...earned,...toUnlock];
    CP.badges=nb;
    await sb.from('profiles').update({badges:nb}).eq('id',CP.id);
    for(const bid of toUnlock){const b=BADGES.find(x=>x.id===bid);setTimeout(()=>showBadgeModal(b),600);}
    renderBadges();
  }
}

