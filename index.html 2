function updateMoreNav(pg){
  document.querySelectorAll('.bb[data-page]').forEach(b=>{
    b.classList.toggle('active', b.dataset.page===pg);
  });
  // Scroll automatique vers le bouton actif
  const activeBtn = document.querySelector('.bb.active');
  if(activeBtn) activeBtn.scrollIntoView({behavior:'smooth', block:'nearest', inline:'center'});
}

