          </div>
          <div class="thermo-res-bar"><div class="thermo-res-fill${isWin?' winner-fill':''}" style="width:${pct}%;"></div></div>
        </div>`;
      }).join('')}
      <div class="thermo-total-votes">${total} participant${total>1?'s':''} au total</div>
    </div>
  </div>`;
}

