// ─── Compression image côté client ───
async function compressImage(file, maxWidth=1200, quality=0.78){
  return new Promise(resolve => {
    const reader = new FileReader();
    reader.onload = e => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let w = img.width, h = img.height;
        if(w > maxWidth){ h = Math.round(h * maxWidth / w); w = maxWidth; }
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
        canvas.toBlob(blob => resolve(blob), 'image/jpeg', quality);
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}

// ─── Upload vers Supabase Storage ───
async function uploadAgPhoto(file){
  const compressed = await compressImage(file);
  const ext = 'jpg';
  const path = `events/${Date.now()}_${Math.random().toString(36).slice(2)}.${ext}`;
  const { data, error } = await sb.storage.from('agenda-images').upload(path, compressed, {
    contentType: 'image/jpeg', upsert: false
  });
  if(error){ showToast('❌ Erreur upload : '+error.message,'var(--rouge)'); return null; }
  const { data: urlData } = sb.storage.from('agenda-images').getPublicUrl(path);
  return urlData.publicUrl;
}

