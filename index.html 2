<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eaucourt-sur-Somme · Plateforme citoyenne</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{--eau:#2C5F6E;--eauM:#4A8FA0;--eauL:#C8DDE4;--eauXL:#EAF4F7;--calc:#F5F0E8;--roseau:#8B7355;--boue:#3D3530;--aube:#E2C97E;--blanc:#FAFAF8;--prairie:#5C7A4E;--rouge:#C0392B;--or:#D4AF37;--argent:#9E9E9E;--bronze:#CD7F32;--admin:#6B35A0;--sidebar:260px;--topbar:62px;--bnav:64px;--r:14px;}
*{margin:0;padding:0;box-sizing:border-box;}html{height:100%;}
body{background:var(--blanc);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased;min-height:100%;overflow-x:hidden;}
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:var(--calc);}::-webkit-scrollbar-thumb{background:var(--eauL);border-radius:3px;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{0%{transform:scale(.85);opacity:0}70%{transform:scale(1.04)}100%{transform:scale(1);opacity:1}}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
@keyframes confetti-fall{to{transform:translateY(110vh) rotate(720deg);opacity:0}}
/* ─── LOADING ─── */
#loading-screen{position:fixed;inset:0;background:linear-gradient(135deg,var(--eau),var(--eauM));z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;transition:opacity .5s;}
#loading-screen.fade{opacity:0;pointer-events:none;}
.ld-logo{font-family:'Playfair Display',serif;font-size:42px;font-weight:900;color:var(--calc);letter-spacing:-1.5px;}
.ld-logo em{font-style:italic;font-weight:400;color:var(--aube);}
.ld-spin{width:36px;height:36px;border:3px solid rgba(200,221,228,.25);border-top-color:var(--aube);border-radius:50%;animation:spin .8s linear infinite;}
.ld-txt{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;color:rgba(200,221,228,.6);text-transform:uppercase;}
/* ─── AVATAR INITIALES ─── */
.av-circle{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-weight:900;font-size:15px;color:#fff;flex-shrink:0;text-transform:uppercase;letter-spacing:.5px;border:2px solid rgba(255,255,255,.3);}
.av-circle.sm{width:30px;height:30px;font-size:11px;}
.av-circle.lg{width:72px;height:72px;font-size:28px;border:3px solid rgba(226,201,126,.4);box-shadow:0 0 0 6px rgba(44,95,110,.4);}
.av-circle.xl{width:90px;height:90px;font-size:34px;}
/* Couleurs avatar */
.avc-0{background:linear-gradient(135deg,#2C5F6E,#4A8FA0);}
.avc-1{background:linear-gradient(135deg,#5C7A4E,#7A9E6A);}
.avc-2{background:linear-gradient(135deg,#8B7355,#B09070);}
.avc-3{background:linear-gradient(135deg,#6B35A0,#9B65D0);}
.avc-4{background:linear-gradient(135deg,#C0392B,#E05040);}
.avc-5{background:linear-gradient(135deg,#D4AF37,#E8C84A);}
.avc-6{background:linear-gradient(135deg,#2E86AB,#4EA6CB);}
.avc-7{background:linear-gradient(135deg,#A34A28,#C36A48);}
/* Picker couleur */
.color-picker{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0;}
.cp-opt{width:36px;height:36px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .2s;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;font-size:13px;}
.cp-opt.selected{border-color:var(--boue);transform:scale(1.15);}
/* ─── AUTH ─── */
#auth-screen{min-height:100vh;display:none;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--eau) 0%,var(--eauM) 100%);padding:20px;position:relative;}
.auth-bg-wave{position:absolute;bottom:0;left:0;width:100%;pointer-events:none;}
.auth-card{background:#fff;border-radius:22px;padding:38px 34px;width:100%;max-width:440px;box-shadow:0 28px 72px rgba(0,0,0,.24);animation:pop .4s cubic-bezier(.34,1.56,.64,1);position:relative;z-index:1;}
@media(max-width:480px){.auth-card{padding:26px 20px;border-radius:16px;}}
.ath{font-family:'Playfair Display',serif;font-size:36px;font-weight:900;color:var(--eau);letter-spacing:-1.2px;text-align:center;line-height:1;}
.ath em{font-style:italic;font-weight:400;color:var(--eauM);}
.auth-sub{font-family:'Playfair Display',serif;font-style:italic;font-size:18px;color:var(--aube);text-align:center;margin:4px 0 26px;}
.atabs{display:flex;background:var(--calc);border-radius:100px;padding:4px;margin-bottom:22px;gap:4px;}
.atab{flex:1;padding:9px;border-radius:100px;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;color:var(--roseau);transition:all .2s;font-weight:500;}
.atab.active{background:#fff;color:var(--eau);font-weight:600;box-shadow:0 2px 8px rgba(0,0,0,.09);}
.aerr{background:rgba(192,57,43,.07);border:1px solid rgba(192,57,43,.2);border-radius:9px;padding:10px 14px;font-size:12px;color:var(--rouge);margin-bottom:14px;display:none;}
.aok{background:rgba(92,122,78,.07);border:1px solid rgba(92,122,78,.2);border-radius:9px;padding:10px 14px;font-size:12px;color:var(--prairie);margin-bottom:14px;display:none;}
/* ─── LAYOUT ─── */
#main-app{display:none;min-height:100vh;}
.sidebar{position:fixed;top:0;left:0;width:var(--sidebar);height:100vh;background:var(--calc);border-right:1px solid var(--eauL);z-index:200;display:flex;flex-direction:column;overflow:hidden;}
.sb-top{padding:22px 18px 18px;border-bottom:1px solid var(--eauL);}
.sb-logo-m{font-family:'Playfair Display',serif;font-weight:900;font-size:21px;color:var(--eau);letter-spacing:-.5px;cursor:pointer;}
.sb-logo-s{font-family:'Playfair Display',serif;font-style:italic;font-size:12px;color:var(--eauM);margin-top:2px;}
.sb-card{margin-top:14px;background:#fff;border-radius:10px;padding:11px 13px;border:1px solid var(--eauL);}
.sb-nm{font-family:'Playfair Display',serif;font-weight:700;font-size:13px;color:var(--boue);margin-bottom:2px;margin-top:7px;}
.sb-ps{font-family:'DM Mono',monospace;font-size:9px;color:var(--eauM);margin-bottom:6px;}
.sb-lvl{display:inline-flex;align-items:center;gap:5px;background:rgba(44,95,110,.08);border-radius:100px;padding:3px 10px;margin-bottom:7px;}
.sb-lvl-d{width:6px;height:6px;border-radius:50%;background:var(--eau);}.sb-lvl-t{font-family:'DM Mono',monospace;font-size:9px;color:var(--eau);}
.sb-admin-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(107,53,160,.12);border-radius:100px;padding:3px 10px;margin-bottom:7px;margin-left:5px;}
.sb-admin-t{font-family:'DM Mono',monospace;font-size:9px;color:var(--admin);}
.xpb{height:5px;background:var(--eauL);border-radius:100px;overflow:hidden;margin-bottom:3px;}
.xpbf{height:100%;background:linear-gradient(90deg,var(--eau),var(--aube));border-radius:100px;transition:width .8s ease;}
.xpl{font-family:'DM Mono',monospace;font-size:7px;color:var(--roseau);display:flex;justify-content:space-between;}
.sb-nav{flex:1;padding:14px 10px;overflow-y:auto;}
.sn{display:flex;align-items:center;gap:11px;width:100%;padding:9px 13px;border-radius:10px;border:none;background:transparent;color:var(--roseau);cursor:pointer;transition:all .2s;margin-bottom:3px;text-align:left;}
.sn:hover{background:rgba(44,95,110,.06);color:var(--eau);}.sn.active{background:rgba(44,95,110,.1);color:var(--eau);}
.sn.admin-nav{color:var(--admin);}.sn.admin-nav:hover{background:rgba(107,53,160,.07);}
.sn-ic{font-size:16px;flex-shrink:0;}.sn-lb{font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;}
.sn-xp{font-family:'DM Mono',monospace;font-size:8px;color:var(--prairie);background:rgba(92,122,78,.1);padding:1px 6px;border-radius:100px;margin-left:auto;}
.sb-bot{padding:10px 10px 18px;border-top:1px solid var(--eauL);}
.sb-out{display:flex;align-items:center;gap:10px;width:100%;padding:9px 13px;border-radius:10px;border:none;background:transparent;color:var(--roseau);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;transition:all .2s;}
.sb-out:hover{background:rgba(192,57,43,.06);color:var(--rouge);}
.cw{margin-left:var(--sidebar);min-height:100vh;background:var(--blanc);}
.ci{max-width:880px;margin:0 auto;padding:0 0 60px;}
.tb{position:sticky;top:0;z-index:100;background:rgba(250,250,248,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--eauL);height:var(--topbar);display:flex;align-items:center;padding:0 28px;justify-content:space-between;box-shadow:0 1px 12px rgba(44,95,110,.05);}
.tb-tt{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--eau);letter-spacing:-.4px;}
.tb-r{display:flex;align-items:center;gap:10px;}
.tb-xp{background:var(--eau);color:var(--aube);padding:5px 14px;border-radius:100px;font-family:'DM Mono',monospace;font-size:10px;}
.tb-admin{background:var(--admin);color:#fff;padding:5px 12px;border-radius:100px;font-family:'DM Mono',monospace;font-size:9px;display:none;}
/* ─── MOBILE ─── */
.mob-tb{display:none;}.bnav{display:none;}
@media(max-width:720px){
  .sidebar{display:none;}.cw{margin-left:0;padding-top:var(--topbar);padding-bottom:var(--bnav);}.tb{display:none;}
  .mob-tb{display:flex;position:fixed;top:0;left:0;right:0;height:var(--topbar);background:rgba(245,240,232,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--eauL);z-index:300;align-items:center;justify-content:space-between;padding:0 16px;box-shadow:0 2px 16px rgba(44,95,110,.07);}
  .mob-logo-m{font-family:'Playfair Display',serif;font-weight:900;font-size:16px;color:var(--eau);}
  .mob-logo-s{font-family:'Playfair Display',serif;font-style:italic;font-size:11px;color:var(--eauM);}
  .mob-r{display:flex;align-items:center;gap:8px;}
  .mob-xp{background:var(--eau);color:var(--aube);padding:4px 11px;border-radius:100px;font-family:'DM Mono',monospace;font-size:9px;cursor:pointer;border:none;}
  .mob-av-btn{cursor:pointer;}
  .bnav{
    display:flex;
    position:fixed;
    bottom:0;
    left:0;
    right:0;
    min-height:var(--bnav);
    padding-bottom:env(safe-area-inset-bottom,0px);
    background:rgba(245,240,232,.97);
    backdrop-filter:blur(20px);
    border-top:1px solid var(--eauL);
    z-index:300;
    align-items:center;
    overflow-x:auto;
    overflow-y:visible;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-left:4px;
    padding-right:4px;
    gap:0;
  }
  .bnav::-webkit-scrollbar{display:none;}
  .bb{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:2px;
    padding:6px 10px;
    border-radius:10px;
    border:none;
    background:transparent;
    color:var(--roseau);
    cursor:pointer;
    transition:all .2s;
    position:relative;
    flex-shrink:0;
    min-width:54px;
    box-sizing:border-box;
  }
  .bb.active{color:var(--eau);background:rgba(44,95,110,.08);}
  .bb .bi{font-size:22px;line-height:1;display:block;}
  .bb .bl{font-family:'DM Mono',monospace;font-size:7px;text-transform:uppercase;letter-spacing:0;white-space:nowrap;display:block;}
  /* ─── (panneau Plus supprimé — nav scrollable) ─── */
  /* ─── Pages et chips mobile ─── */
  .ci{padding:0;overflow-x:hidden;}
  .page{padding:16px 16px 100px!important;}
  .page-no-pad{padding:0 0 100px!important;}
  .hero,.phero{border-radius:0;}
  /* Chips : scroll horizontal sans débordement */
  .chips{
    flex-wrap:nowrap;
    overflow-x:auto;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom:6px;
    /* Étendre jusqu'aux bords de l'écran pour plus d'espace */
    margin-left:-16px;
    margin-right:-16px;
    padding-left:16px;
    padding-right:16px;
    /* Masquer le débordement proprement */
    max-width:calc(100vw);
    box-sizing:border-box;
  }
  .chips::-webkit-scrollbar{display:none;}
  /* Onglets : scroll si nécessaire */
  .cdm-tabs{flex-wrap:nowrap;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;max-width:100%;}
  .cdm-tabs::-webkit-scrollbar{display:none;}
  .ag-view-toggle{flex-shrink:0;max-width:100%;}
  /* Contrôles avec chips : empêcher le débordement du conteneur */
  #ag-filters,#cdm-cat-chips,#filter-als,#filter-ann{
    max-width:100vw;
    overflow:hidden;
  }
}
@media(max-width:900px){:root{--sidebar:220px;}}
/* ─── PAGES ─── */
.page{display:none;padding:28px 28px 40px;animation:fadeUp .3s ease;}.page.active{display:block;}
/* ─── HERO ─── */
.hero{background:var(--eau);border-radius:var(--r);padding:36px 28px 40px;position:relative;overflow:hidden;margin-bottom:24px;}
@media(max-width:720px){.hero{border-radius:0;margin-bottom:0;}}
.hn{position:absolute;inset:0;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.65' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");}
.hc{position:relative;z-index:1;}
.h-tag{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;color:rgba(200,221,228,.7);text-transform:uppercase;margin-bottom:8px;}
.h-nm{font-family:'Playfair Display',serif;font-size:40px;font-weight:900;color:var(--calc);letter-spacing:-1.5px;line-height:.95;}
.h-lv{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:24px;color:var(--aube);margin-bottom:16px;line-height:1.2;}
.xpbw{max-width:380px;}.xpbl{display:flex;justify-content:space-between;font-family:'DM Mono',monospace;font-size:9px;color:rgba(200,221,228,.6);margin-bottom:5px;}
.xpbt{height:6px;background:rgba(200,221,228,.15);border-radius:100px;overflow:hidden;}
/* ─── STATS ─── */
.srow{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px;}
@media(max-width:720px){.srow{gap:0;margin-bottom:0;}}
.sbox{background:#fff;border-radius:var(--r);border:1px solid var(--eauL);padding:18px 16px;text-align:center;}
@media(max-width:720px){.sbox{border-radius:0;border:none;border-right:1px solid var(--eauL);background:var(--calc);}.sbox:last-child{border-right:none;}}
.si{font-size:20px;margin-bottom:5px;}
.sv{font-family:'Playfair Display',serif;font-size:26px;font-weight:900;color:var(--eau);line-height:1;}
.sl{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.8px;color:var(--roseau);text-transform:uppercase;margin-top:3px;}
/* ─── GRIDS ─── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
@media(max-width:900px){.g3{grid-template-columns:repeat(2,1fr);}.g4{grid-template-columns:repeat(3,1fr);}}
@media(max-width:720px){.g2{grid-template-columns:1fr;}.g3{grid-template-columns:repeat(2,1fr);}.g4{grid-template-columns:repeat(2,1fr);}}
/* ─── SECTION TITLE ─── */
.st-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:18px;flex-wrap:wrap;gap:10px;}
.st-tag{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--eauM);margin-bottom:6px;display:flex;align-items:center;gap:8px;}
.st-tag::before{content:'';display:inline-block;width:14px;height:1px;background:var(--eauM);}
.st-h{font-family:'Playfair Display',serif;font-size:24px;font-weight:900;color:var(--eau);letter-spacing:-.5px;line-height:1.05;}
.st-sub{font-weight:300;color:var(--roseau);font-size:12px;line-height:1.65;margin-top:4px;}
/* ─── CARD ─── */
.card{background:#fff;border-radius:var(--r);border:1px solid var(--eauL);padding:18px 20px;transition:all .2s;}
.cc{cursor:pointer;}.cc:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(44,95,110,.1);}
.cstack{display:flex;flex-direction:column;gap:10px;}
/* ─── PILL / CHIP ─── */
.pill{display:inline-block;padding:3px 9px;border-radius:100px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;white-space:nowrap;}
.chips{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:18px;}
.chip{padding:5px 14px;border-radius:100px;border:1px solid var(--eauL);background:transparent;color:var(--roseau);font-family:'DM Mono',monospace;font-size:9px;cursor:pointer;text-transform:uppercase;letter-spacing:.8px;transition:all .2s;white-space:nowrap;flex-shrink:0;}
.chip.on{background:var(--eau);border-color:var(--eau);color:#fff;}
/* ─── BUTTONS ─── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border:none;padding:11px 22px;border-radius:100px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:13px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn:active{transform:scale(.96);}
.bp{background:var(--eau);color:#fff;}.bp:hover{background:var(--eauM);}
.ba{background:var(--admin);color:#fff;}.ba:hover{background:#8A55C0;}
.bgh{background:var(--calc);color:var(--boue);border:1px solid var(--eauL);}
.bo{background:transparent;color:var(--eau);border:1.5px solid var(--eau);}
.bfu{width:100%;}.bsm{padding:6px 14px;font-size:12px;}
.bdng{background:transparent;color:var(--rouge);border:1.5px solid var(--rouge);}
.bdng-fill{background:var(--rouge);color:#fff;}
.br{display:flex;gap:10px;flex-wrap:wrap;}
/* ─── FORM ─── */
.fc{display:flex;flex-direction:column;gap:14px;}
.field label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--roseau);display:block;margin-bottom:5px;}
.fi,.fs,.ft{background:var(--calc);border:1.5px solid transparent;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-weight:300;font-size:14px;color:var(--boue);outline:none;width:100%;transition:border-color .2s;}
.fi:focus,.fs:focus,.ft:focus{border-color:var(--eau);background:#fff;}
.ft{resize:vertical;min-height:80px;}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:480px){.fr2{grid-template-columns:1fr;}}
/* ─── MODAL ─── */
.modal{display:none;position:fixed;inset:0;background:rgba(61,53,48,.6);z-index:2000;align-items:flex-end;justify-content:center;}
@media(min-width:721px){.modal{align-items:center;}}
.modal.open{display:flex;}
.mbox{background:#fff;border-radius:20px 20px 0 0;width:100%;max-width:580px;max-height:92vh;overflow-y:auto;padding:24px;padding-bottom:40px;}
@media(min-width:721px){.mbox{border-radius:20px;padding:32px;animation:pop .3s cubic-bezier(.34,1.56,.64,1);}}
.mpill{width:40px;height:4px;background:var(--eauL);border-radius:100px;margin:0 auto 20px;}
@media(min-width:721px){.mpill{display:none;}}
.mtitle{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--eau);margin-bottom:20px;line-height:1.2;}
.mtitle.admin-title{color:var(--admin);}
/* ─── ADMIN BANNER ─── */
.admin-banner{background:linear-gradient(135deg,rgba(107,53,160,.1),rgba(107,53,160,.05));border:1px solid rgba(107,53,160,.2);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.admin-banner p{font-family:'DM Mono',monospace;font-size:10px;color:var(--admin);letter-spacing:.5px;}
/* ─── ADMIN ACTION BTN (on cards) ─── */
.admin-actions{display:flex;gap:6px;margin-top:12px;padding-top:12px;border-top:1px dashed rgba(107,53,160,.2);}
/* ─── TOAST ─── */
#toast{position:fixed;bottom:24px;left:50%;transform:translate(-50%,24px);padding:10px 22px;border-radius:100px;font-size:13px;font-weight:500;box-shadow:0 8px 28px rgba(0,0,0,.2);z-index:9000;opacity:0;pointer-events:none;transition:all .4s cubic-bezier(.34,1.56,.64,1);white-space:nowrap;color:#fff;}
#toast.show{transform:translate(-50%,0);opacity:1;}
@media(max-width:720px){#toast{bottom:72px;}}
