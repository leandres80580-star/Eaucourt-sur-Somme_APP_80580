      ${(q.options||[]).map(opt=>{
        const pct = total>0?Math.round((opt.votes||0)/total*100):0;
        const isWin = (opt.votes||0)===maxVotes && maxVotes>0;
        return `<div class="thermo-res-bar-wrap">
          <div class="thermo-res-label">
            <span class="thermo-res-txt">${opt.emoji||'▸'} ${esc(opt.label)}${isWin?' 🏆':''}</span>
