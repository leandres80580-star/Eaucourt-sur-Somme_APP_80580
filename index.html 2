// ── Géolocalisation GPS ──
function getGPS(){
  const btn=document.getElementById('btn-gps');
  const status=document.getElementById('gps-status');
  if(!navigator.geolocation){
    status.textContent='❌ Géolocalisation non supportée par votre navigateur';
    return;
  }
  btn.classList.add('loading');
  btn.textContent='⏳ Localisation…';
  status.textContent='Recherche de votre position…';
  navigator.geolocation.getCurrentPosition(
    (pos)=>{
      const lat=pos.coords.latitude.toFixed(6);
      const lng=pos.coords.longitude.toFixed(6);
      document.getElementById('al-gps').value=lat+', '+lng;
      status.innerHTML=`✅ Position obtenue · précision ±${Math.round(pos.coords.accuracy)}m`;
      btn.textContent='✅ Position obtenue';
      btn.classList.remove('loading');
      btn.style.background='var(--prairie)';
    },
    (err)=>{
      const msgs={1:'Accès refusé — autorisez la localisation',2:'Position indisponible',3:'Délai dépassé'};
      status.textContent='❌ '+(msgs[err.code]||'Erreur inconnue');
      btn.textContent='📍 Ma position';
      btn.classList.remove('loading');
      btn.style.background='';
    },
    {enableHighAccuracy:true,timeout:10000,maximumAge:0}
  );
}

