function thermoCardHTML(q){
  const total = getThermoTotal(q);
  const maxVotes = Math.max(...(q.options||[]).map(o=>o.votes||0),0);
  const adminDel = isAdmin?`<button onclick="deleteThermo(${q.id})" style="background:none;border:none;font-size:10px;color:var(--rouge);cursor:pointer;padding:0;font-family:'DM Mono',monospace;white-space:nowrap;" title="Supprimer ce sondage">🗑️ Supprimer</button>`:'';
