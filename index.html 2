async function postMur(){
  if(!CP) return showToast('Connectez-vous !!','var(--rouge)');
  const contenu=document.getElementById('mur-txt').value.trim();
  if(!contenu||contenu.length>280) return;
  const btn=document.getElementById('mur-btn');
  btn.disabled=true; btn.textContent='…';
  const {error}=await sb.from('mur_voisins').insert({
    contenu, auteur_id:CP.id, auteur_nom:CP.nom,
    auteur_color:CP.avatar_color||0, liked_by:[]
  });
  btn.textContent='Partager';
  if(error){showToast('❌ '+error.message,'var(--rouge)');btn.disabled=false;return;}
  document.getElementById('mur-txt').value='';
