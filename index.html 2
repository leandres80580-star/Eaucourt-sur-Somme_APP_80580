    </div>`;
  }

  // Historique (questions passées/clôturées)
  const past = thermoData.filter(q=>q.id!==(active?.id)||q.cloturee);
  const history = past.filter(q=>q.id!==(active?.id));
  if(history.length){
    historyEl.innerHTML = `
      <div class="st-row"><div><div class="st-tag">Historique</div><div class="st-h">Sondages passés</div></div></div>
