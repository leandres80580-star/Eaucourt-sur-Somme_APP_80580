              <span class="thermo-opt-emoji">${opt.emoji||'▸'}</span>
              <span class="thermo-opt-label">${esc(opt.label)}${myVote?' <span style="font-size:9px;color:var(--aube);">✓</span>':''}</span>
              ${hasVoted?`<span class="thermo-opt-pct">${pct}%${isWin?' 🏆':''}</span>`:''}
            </div>
          </button>`;
        }).join('')}
      </div>
      <div class="thermo-meta">
        <span>📊 ${total} vote${total>1?'s':''}</span>
        ${hasVoted?'<span style="color:var(--prairie);">✅ Vous avez voté</span>':'<span>Cliquez pour voter</span>'}
      </div>
    </div>
  </div>`;
}

// ─── Vote ───
async function voteThermo(questionId, optionIndex){
  if(!CP) return showToast('Connectez-vous !!','var(--rouge)');
  const q = thermoData.find(x=>x.id===questionId);
  if(!q || hasVotedThermo(questionId)) return;
  // Mise à jour optimiste
  const opts = JSON.parse(JSON.stringify(q.options||[]));
  if(!opts[optionIndex]) return;
  opts[optionIndex].votes = (opts[optionIndex].votes||0)+1;
  if(!opts[optionIndex].votants) opts[optionIndex].votants=[];
  opts[optionIndex].votants.push(CP.id);
  const votants = [...(q.votants||[]), CP.id];
  q.options = opts;
  q.votants = votants;
  renderThermo();
  renderThermoHomeWidget();
  // Enregistrer en DB
  const {error} = await sb.from('thermo_questions').update({options:opts, votants}).eq('id',questionId);
  if(error){ showToast('❌ Erreur lors du vote','var(--rouge)'); return; }
  showToast('🌡️ Vote enregistré, merci !','#1a3a4a');
}

async function homeVoteThermo(questionId, optionIndex){
  await voteThermo(questionId, optionIndex);
}

// ─── Supprimer (admin) ───
async function deleteThermo(id){
  if(!isAdmin || !confirm('Supprimer ce sondage définitivement ? Les votes seront perdus.')) return;
  const {error} = await sb.from('thermo_questions').delete().eq('id',id);
  if(error){ showToast('Erreur : '+error.message,'#C0392B'); return; }
  showToast('🗑️ Sondage supprimé','var(--prairie)');
  await loadThermo();
}

// ─── Clôturer ───
async function cloturerThermo(questionId){
  if(!isAdmin || !confirm('Clôturer cette question ?')) return;
  await sb.from('thermo_questions').update({cloturee:true}).eq('id',questionId);
  showToast('🔒 Question clôturée','var(--roseau)');
  await loadThermo();
}

// ─── Créer une question (admin) ───
async function submitThermo(){
  if(!isAdmin) return;
  const question = document.getElementById('th-question').value.trim();
  if(!question) return showToast('⚠️ La question est obligatoire','var(--rouge)');
  const options = [];
  for(let i=0;i<5;i++){
    const label = document.getElementById('th-o-'+i)?.value.trim();
    const emoji = document.getElementById('th-e-'+i)?.value.trim()||'▸';
    if(label) options.push({label, emoji, votes:0, votants:[]});
  }
  if(options.length<2) return showToast('⚠️ Au moins 2 réponses requises','var(--rouge)');
  const btn = document.getElementById('btn-th-sub');
  btn.innerHTML='<span class="sp"></span>';btn.classList.add('loading-btn');
  const date_fin = document.getElementById('th-end').value || null;
  const {error} = await sb.from('thermo_questions').insert({
    question, options, votants:[], date_fin, cloturee:false
  });
  btn.innerHTML='Publier la question'; btn.classList.remove('loading-btn');
  if(error){showToast('❌ '+error.message,'var(--rouge)');return;}
  closeModal('modal-thermo-create');
  document.getElementById('th-question').value='';
  document.getElementById('th-end').value='';
  showToast('🌡️ Question publiée !','#1a3a4a');
  await loadThermo();
  showPage('thermo');
}


// ══════════════════════════════════════════════
//  BOURSE DU COUP DE MAIN
// ══════════════════════════════════════════════

const CDM_CATS = {
  Jardinage:    {emoji:'🌱', color:'#4A6741'},
  Bricolage:    {emoji:'🔧', color:'#8B5E3C'},
  Transport:    {emoji:'🚗', color:'#2C5F6E'},
  Garde:        {emoji:'👶', color:'#9B4F8F'},
  Cuisine:      {emoji:'🍲', color:'#C8943A'},
  Informatique: {emoji:'💻', color:'#2C5F6E'},
  Autre:        {emoji:'✨', color:'#888'},
};

async function loadCdm(){
  const {data} = await sb.from('coups_de_main')
    .select('*').order('created_at',{ascending:false});
  cdmData = data || [];
  renderCdm();
  renderCdmHomeWidget();
}

function renderCdm(){
  const el = document.getElementById('cdm-list');
  if(!el) return;
  let items = cdmData;
  if(cdmTab !== 'all') items = items.filter(d=>d.type_service===cdmTab);
  if(cdmCat !== 'all') items = items.filter(d=>d.categorie===cdmCat);

  if(!items.length){
    const msg = cdmTab==="offre" ? "Aucune offre pour l'instant" : cdmTab==="demande" ? "Aucune demande pour l'instant" : "Aucune annonce pour l'instant";
    el.innerHTML = `<div class="cdm-empty"><div class="cdm-empty-ico">${cdmTab==='offre'?'✋':'🙏'}</div>
      <div style="font-family:'Playfair Display',serif;font-style:italic;font-size:19px;color:var(--roseau);">${msg}</div>
      <div style="font-size:12px;color:var(--roseau);opacity:.5;margin-top:6px;">Soyez le premier à en créer une !</div></div>`;
    return;
  }
  el.innerHTML = items.map(d=>cdmCardHTML(d)).join('');
}

function cdmCardHTML(d){
  const cat   = CDM_CATS[d.categorie] || CDM_CATS.Autre;
  const isOwn = CP && d.auteur_id === CP.id;
  const xpVal = d.type_service==='offre' ? 12 : 6;

  return `<div class="cdm-card ${d.type_service}" id="cdmc-${d.id}">
    <div class="cdm-card-accent"></div>
    <div class="cdm-card-body">
      <div class="cdm-card-head">
        <div>
          <div style="display:flex;gap:6px;align-items:center;margin-bottom:7px;flex-wrap:wrap;">
            <span class="cdm-type-badge ${d.type_service}">${d.type_service==='offre'?'✋ Offre':'🙏 Demande'}</span>
            <span class="cdm-cat-badge">${cat.emoji} ${d.categorie}</span>
          </div>
          <div class="cdm-titre">${esc(d.titre)}</div>
        </div>
      </div>
      ${d.description?`<div class="cdm-desc">${esc(d.description)}</div>`:''}
      ${d.disponibilites?`<div style="font-size:11px;color:var(--eauM);margin-bottom:8px;display:flex;align-items:center;gap:5px;">🗓️ ${esc(d.disponibilites)}</div>`:''}
      <div class="cdm-card-foot">
        ${makeAvHTML(d.auteur_nom||'?', d.auteur_color||0, 'sm')}
        <span class="cdm-author">${esc(d.auteur_nom||'—')}</span>
        <span class="cdm-xp-chip">⭐ +${xpVal} XP</span>
        ${d.contact?`<a class="cdm-contact-btn" href="tel:${d.contact.replace(/\s/g,'')}" onclick="event.stopPropagation()">📞 Contacter</a>`:`<button class="cdm-contact-btn" onclick="showToast('Contactez ce voisin directement.','var(--eau)')">💬 Contacter</button>`}
        ${isOwn||isAdmin?`<button class="cdm-del-btn" onclick="deleteCdm(${d.id})" title="Supprimer">🗑️</button>`:''}
      </div>
    </div>
  </div>`;
}

// ─── Onglets & filtres ───
function setCdmTab(t){
  cdmTab=t;
  ['offre','demande','all'].forEach(x=>{
    const btn=document.getElementById('cdm-t-'+x);
    if(btn){
      btn.classList.toggle('active',x===t);
      if(x===t) btn.classList.add(t==='offre'?'offre':t==='demande'?'demande':'');
      else btn.classList.remove('offre','demande');
    }
  });
  renderCdm();
}

function setCdmCat(cat){
  cdmCat=cat;
  document.querySelectorAll('#cdm-cat-chips .chip').forEach(c=>c.classList.toggle('on',c.dataset.cdmcat===cat));
  renderCdm();
}

// ─── Ouvrir modal ───
function openCdmModal(type){
  if(!CP) return showToast('Connectez-vous !!','var(--rouge)');
  const titleEl  = document.getElementById('cdm-modal-title');
  const typeEl   = document.getElementById('cdm-modal-type');
  const xpEl     = document.getElementById('cdm-xp-badge');
  const btnEl    = document.getElementById('btn-cdm-sub');
  if(type==='offre'){
    if(titleEl) titleEl.textContent = 'Proposer un coup de main';
    if(xpEl) xpEl.textContent = '+12 XP pour une offre';
    if(btnEl) btnEl.textContent = 'Publier l\'offre';
  } else {
    if(titleEl) titleEl.textContent = 'Demander un coup de main';
    if(xpEl) xpEl.textContent = '+6 XP pour une demande';
    if(btnEl) btnEl.textContent = 'Publier la demande';
  }
  if(typeEl) typeEl.value = type;
  openModal('modal-cdm');
}

// ─── Créer ───
async function submitCdm(){
  if(!CP) return;
  const type  = document.getElementById('cdm-modal-type').value;
  const titre = document.getElementById('cdm-titre').value.trim();
  if(!titre) return showToast('Titre obligatoire','var(--rouge)');
  const btn = document.getElementById('btn-cdm-sub');
  btn.innerHTML='<span class="sp"></span>';btn.classList.add('loading-btn');
  const xp = type==='offre' ? 12 : 6;
  const {error} = await sb.from('coups_de_main').insert({
    type_service: type,
    titre,
    categorie:       document.getElementById('cdm-cat-sel').value,
    description:     document.getElementById('cdm-desc').value.trim()||null,
    disponibilites:  document.getElementById('cdm-dispo').value.trim()||null,
    contact:         document.getElementById('cdm-contact').value.trim()||null,
    auteur_id:       CP.id,
    auteur_nom:      CP.nom,
    auteur_color:    CP.avatar_color||0,
  });
  btn.innerHTML='Publier'; btn.classList.remove('loading-btn');
  if(error){showToast('❌ '+error.message,'var(--rouge)');return;}
  closeModal('modal-cdm');
  ['cdm-titre','cdm-desc','cdm-dispo','cdm-contact'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  showToast('🤲 Publié, merci pour l\'entraide !','#6B4226');
  await addXP(xp, type==='offre'?'Coup de main proposé':'Aide demandée');
  await loadCdm();
  showPage('bourse');
}

// ─── Supprimer ───
async function deleteCdm(id){
  if(!confirm('Supprimer cette annonce ?')) return;
  const {error}=await sb.from('coups_de_main').delete().eq('id',id);
  if(error) return showToast('❌ Erreur','var(--rouge)');
  cdmData=cdmData.filter(d=>d.id!==id);
  renderCdm();
  renderCdmHomeWidget();
  showToast('🗑️ Annonce supprimée','var(--roseau)');
}

// ─── Widget accueil ───
function renderCdmHomeWidget(){
  const el = document.getElementById('cdm-home-widget');
  if(!el) return;
  const recent = cdmData.slice(0,4);
  if(!recent.length){
    el.innerHTML='<div style="background:rgba(200,148,58,.06);border:1px dashed rgba(200,148,58,.2);border-radius:12px;padding:16px;text-align:center;"><div style="font-size:12px;color:var(--roseau);font-style:italic;">Aucune annonce pour l\u2019instant. Soyez le premier !</div></div>';
    return;
  }
  const offres   = cdmData.filter(d=>d.type_service==='offre').length;
  const demandes = cdmData.filter(d=>d.type_service==='demande').length;
  el.innerHTML=`<div class="cdm-home-widget">
    <div class="hn"></div>
    <div class="cdm-home-inner">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div style="font-family:'DM Mono',monospace;font-size:9px;color:rgba(245,215,142,.6);letter-spacing:1px;text-transform:uppercase;">Annonces récentes</div>
        <button onclick="showPage('bourse')" style="background:none;border:none;font-size:10px;color:rgba(245,215,142,.55);cursor:pointer;font-family:'DM Mono',monospace;">Voir tout →</button>
      </div>
      <div class="cdm-home-preview">
        ${recent.map(d=>`<div class="cdm-home-item" onclick="showPage('bourse')">
          <div class="cdm-home-item-type ${d.type_service}">${d.type_service==='offre'?'✋ Offre':'🙏 Demande'}</div>
          <div class="cdm-home-item-titre">${esc(d.titre.length>40?d.titre.slice(0,38)+'…':d.titre)}</div>
        </div>`).join('')}
      </div>
      <div class="cdm-home-stat">${offres} offre${offres>1?'s':''} · ${demandes} demande${demandes>1?'s':''}</div>
    </div>
  </div>`;
}


