// ─── Calendrier mini ───
const AG_MONTHS = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const AG_DAYS   = ['L','M','M','J','V','S','D'];

function renderAgCal(){
  const yr=agCalYear, mo=agCalMonth;
  const title = AG_MONTHS[mo]+' '+yr;
  document.getElementById('ag-cal-title').textContent=title;

  const firstDay = new Date(yr,mo,1).getDay(); // 0=dim
  const startOff  = (firstDay===0?6:firstDay-1); // lundi=0
  const daysInMo  = new Date(yr,mo+1,0).getDate();
  const today     = new Date();

  // Jours avec événements ce mois
  const eventDays = new Set(
    agData.filter(e=>{
      const d=new Date(e.date_event);
      return d.getFullYear()===yr && d.getMonth()===mo;
    }).map(e=>new Date(e.date_event).getDate())
  );

  let html = AG_DAYS.map(d=>`<div class="ag-cal-dow">${d}</div>`).join('');
  // Cases vides avant le 1er
  for(let i=0;i<startOff;i++) html+=`<div class="ag-cal-day other-month"></div>`;
  for(let d=1;d<=daysInMo;d++){
    const isToday = (d===today.getDate()&&mo===today.getMonth()&&yr===today.getFullYear());
    const hasFv   = eventDays.has(d);
    const isSel   = agCalSelected===d;
    html+=`<div class="ag-cal-day${isToday?' today':''}${hasFv?' has-event':''}${isSel?' selected':''}" onclick="agCalSelect(${d})">${d}</div>`;
  }
  document.getElementById('ag-cal-grid').innerHTML=html;
  renderAgCalEvents();
}

function agCalSelect(d){
  agCalSelected = agCalSelected===d?null:d;
  renderAgCal();
}

function renderAgCalEvents(){
  const el=document.getElementById('ag-cal-events');
  if(!agCalSelected){el.innerHTML='';return;}
  const filtered=agData.filter(e=>{
    const d=new Date(e.date_event);
    return d.getFullYear()===agCalYear&&d.getMonth()===agCalMonth&&d.getDate()===agCalSelected;
  });
  el.innerHTML=filtered.length?filtered.map(e=>agCardHTML(e)).join('')
    :`<div style="text-align:center;padding:20px;font-size:12px;color:var(--roseau);">Aucun événement ce jour</div>`;
}

function agCalNav(dir){
  agCalMonth+=dir;
  if(agCalMonth<0){agCalMonth=11;agCalYear--;}
  if(agCalMonth>11){agCalMonth=0;agCalYear++;}
  agCalSelected=null;
  renderAgCal();
}

